{
  "name": "tool-browser",
  "version": "1.0.0",
  "type": "tool",
  "displayName": "Browser Automation",
  "description": "Navigate, interact with, and screenshot web pages using Puppeteer",
  "entry": "./index.ts",
  "config": {
    "type": "object",
    "properties": {
      "headless": { "type": "boolean", "description": "Run browser in headless mode", "default": true },
      "timeout": { "type": "number", "description": "Navigation timeout in ms", "default": 30000 }
    }
  }
}
